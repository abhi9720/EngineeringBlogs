{
  "type": "object",
  "required": [
    "title",
    "description",
    "date",
    "tags",
    "category",
    "subcategory"
  ],
  "properties": {
    "title": { "type": "string" },
    "description": { "type": "string" },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "author": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "category": { "type": "string" },
    "subcategory": { "type": "string" },
    "coverImage": { "type": "string" },
    "slug": { "type": "string" },
    "draft": { "type": "boolean" },
    "updatedAt": { "type": "string" }
  },
  "additionalProperties": true
}
